# aibiblegospels.com environment variables
# Copy to .env.local for local dev. Set the same in Vercel for production.

# ── TikTok OAuth (for /connect/tiktok) ────────────────────────────────
TIKTOK_CLIENT_KEY=

# ── Resend (for /api/subscribe — Deut 28 cheatsheet capture) ──────────
# API key from https://resend.com/api-keys
# Needs Audiences:write + Sending:send scopes (i.e. Full access).
RESEND_API_KEY=

# Audience ID from https://resend.com/audiences
# Create an audience named "AI Bible Gospels Subscribers" and paste the UUID here.
RESEND_AUDIENCE_ID=

# ── BMB CRM lead ingestion (for /api/subscribe → LeadStack) ───────────
# Optional. When BOTH are set, every signup is also mirrored into the BMB
# CRM as a contact. If unset, the subscribe form works exactly as before
# (the CRM push silently no-ops). See bmbaiautomations/docs/sales for the
# follow-up framework that consumes these leads.
BMB_CRM_INGEST_URL=https://bmb-crm.vercel.app
# LeadStack API key (live mode), format: lsk_live_<id>:<secret>
BMB_CRM_API_KEY=
